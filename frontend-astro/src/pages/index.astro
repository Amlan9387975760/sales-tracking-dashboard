---
import Layout from '../layouts/Layout.astro';
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const currentMonth = MONTHS[new Date().getMonth()];
const currentYear = new Date().getFullYear();
---
<Layout>

<!-- HEADER -->
<header class="text-white px-6 lg:px-10 py-4 flex items-center justify-between shadow-2xl sticky top-0 z-40" style="background: linear-gradient(135deg,#1a0533 0%,#3b0764 100%)">
  <div class="flex items-center gap-3">
    <img src="/logo.png" alt="Vantage Fit" class="h-9 w-auto drop-shadow" onerror="this.style.display='none'" />
    <div>
      <div class="flex items-center gap-2">
        <h1 class="text-base font-bold tracking-tight">Sales Information Dashboard</h1>
        <span class="hidden sm:inline-block px-2 py-0.5 rounded-full text-xs font-semibold" style="background:rgba(244,63,94,0.25);color:#fda4af">INTERNAL</span>
      </div>
      <p class="text-purple-300 text-xs mt-0.5">Vantage Fit · Lifecycle Intelligence</p>
    </div>
  </div>
  <div class="flex items-center gap-2 sm:gap-3">
    <span id="last-updated" class="hidden lg:block text-purple-300 text-xs"></span>
    <button id="pdf-btn" class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold border border-purple-500 text-purple-200 hover:bg-purple-800 transition-colors">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
      Export PDF
    </button>
    <button id="upload-btn" class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-bold text-white shadow-vf transition-all hover:opacity-90" style="background:linear-gradient(135deg,#f43f5e,#fb923c)">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
      Upload Report
    </button>
  </div>
</header>

<!-- FY TABS -->
<div class="bg-white border-b border-slate-100 px-6 lg:px-10 shadow-sm">
  <div class="flex gap-0 overflow-x-auto" id="fy-tabs"></div>
</div>

<!-- MONTH + ERASE BAR -->
<div class="bg-white border-b border-slate-100 px-6 lg:px-10 py-2.5 flex items-center justify-between">
  <div class="flex items-center gap-3">
    <label class="text-xs text-slate-400 font-medium uppercase tracking-wide">Viewing</label>
    <select id="month-select" class="border border-slate-200 rounded-lg px-3 py-1.5 text-sm font-semibold text-slate-700 focus:outline-none focus:ring-2 bg-white" style="--tw-ring-color:#f43f5e">
      <option>Loading...</option>
    </select>
    <a href={`${import.meta.env.BASE_URL}full-year`} class="flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg border border-purple-200 text-purple-600 hover:bg-purple-600 hover:text-white hover:border-purple-600 transition-colors">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      Full Year
    </a>
  </div>
  <button id="erase-btn" class="flex items-center gap-1.5 text-xs text-slate-400 hover:text-red-500 border border-slate-200 hover:border-red-300 px-3 py-1.5 rounded-lg transition-colors">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    Erase Month
  </button>
</div>

<!-- TOAST -->
<div id="toast" class="fixed top-20 right-6 z-50 hidden max-w-sm"></div>

<!-- MAIN -->
<main id="dashboard-main" class="px-6 lg:px-10 py-6 space-y-5 max-w-screen-2xl mx-auto">

  <!-- KPI CARDS -->
  <div class="grid grid-cols-2 xl:grid-cols-4 gap-4">
    <div class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex items-center gap-4 group hover:shadow-md transition-shadow">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background:linear-gradient(135deg,#d1fae5,#a7f3d0)">
        <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
      </div>
      <div>
        <p class="text-2xl font-black text-slate-800" id="kpi-active">—</p>
        <p class="text-xs font-semibold text-emerald-600 mt-0.5 uppercase tracking-wide">Active</p>
      </div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex items-center gap-4 hover:shadow-md transition-shadow">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background:linear-gradient(135deg,#dbeafe,#bfdbfe)">
        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.868V15.131a1 1 0 01-1.447.9L15 14M3 8h12v8H3a1 1 0 01-1-1V9a1 1 0 011-1z"/></svg>
      </div>
      <div>
        <p class="text-2xl font-black text-slate-800" id="kpi-demo">—</p>
        <p class="text-xs font-semibold text-blue-600 mt-0.5 uppercase tracking-wide">Demo</p>
      </div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex items-center gap-4 hover:shadow-md transition-shadow">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background:linear-gradient(135deg,#fee2e2,#fecaca)">
        <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <div>
        <p class="text-2xl font-black text-slate-800" id="kpi-expired">—</p>
        <p class="text-xs font-semibold text-red-500 mt-0.5 uppercase tracking-wide">Demo Expired</p>
      </div>
    </div>
    <div class="rounded-2xl p-5 shadow-card flex items-center gap-4 hover:shadow-md transition-shadow" style="background:linear-gradient(135deg,#1a0533,#3b0764)">
      <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      </div>
      <div>
        <p class="text-2xl font-black text-white" id="kpi-total">—</p>
        <p class="text-xs font-semibold text-purple-300 mt-0.5 uppercase tracking-wide">Total</p>
      </div>
    </div>
  </div>

  <!-- FY TREND + REGION CHARTS -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-5">
    <div class="lg:col-span-3 bg-white rounded-2xl p-6 shadow-card border border-slate-100">
      <div class="flex items-center justify-between mb-3">
        <div>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Company Trend</p>
          <p class="text-xs text-slate-400 mt-0.5">FY <span id="trend-fy-label" class="font-semibold text-slate-500"></span></p>
        </div>
      </div>
      <div class="h-52"><canvas id="trendChart"></canvas></div>
    </div>
    <div class="lg:col-span-2 bg-white rounded-2xl p-6 shadow-card border border-slate-100">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Companies by Region</p>
      <div class="h-52"><canvas id="regionChart"></canvas></div>
    </div>
  </div>

  <!-- CHART + LIFECYCLE -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-5">
    <div class="lg:col-span-2 bg-white rounded-2xl p-6 shadow-card border border-slate-100">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Status Distribution</p>
      <div class="flex items-center justify-center h-48">
        <canvas id="statusChart"></canvas>
      </div>
    </div>
    <div class="lg:col-span-3 bg-white rounded-2xl p-6 shadow-card border border-slate-100">
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Lifecycle Movement</p>
          <p class="text-xs text-slate-400 mt-0.5">vs previous month upload</p>
        </div>
      </div>
      <div id="lifecycle-summary" class="grid grid-cols-3 gap-3 mb-4 hidden">
        <div class="rounded-xl p-3 text-center" style="background:linear-gradient(135deg,#d1fae5,#a7f3d0)">
          <p class="text-xl font-black text-emerald-700" id="lc-converted">0</p>
          <p class="text-xs font-semibold text-emerald-600 mt-0.5">Demo → Active</p>
        </div>
        <div class="bg-red-50 rounded-xl p-3 text-center border border-red-100">
          <p class="text-xl font-black text-red-600" id="lc-expired">0</p>
          <p class="text-xs font-semibold text-red-500 mt-0.5">→ Expired</p>
        </div>
        <div class="bg-blue-50 rounded-xl p-3 text-center border border-blue-100">
          <p class="text-xl font-black text-blue-600" id="lc-reengaged">0</p>
          <p class="text-xs font-semibold text-blue-500 mt-0.5">Re-engaged</p>
        </div>
      </div>
      <div id="lifecycle-list" class="space-y-2 max-h-48 overflow-y-auto pr-1">
        <p class="text-slate-300 text-sm text-center py-8">Upload data for two months to see lifecycle changes</p>
      </div>
    </div>
  </div>

  <!-- ATTENTION REQUIRED -->
  <div class="bg-white rounded-2xl shadow-card border border-red-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-red-50 flex items-center gap-2" style="background:linear-gradient(135deg,#fff1f2,#fff7ed)">
      <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
      <p class="text-xs font-bold text-red-600 uppercase tracking-widest">Attention Required — Demo Expired Companies</p>
    </div>
    <div id="attention-list" class="p-5 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      <p class="text-slate-300 text-sm col-span-full text-center py-4">No companies require attention</p>
    </div>
  </div>

  <!-- COMPANIES TABLE -->
  <div class="bg-white rounded-2xl shadow-card border border-slate-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">All Companies</p>
      <div class="flex flex-wrap items-center gap-2">
        <select id="filter-status" class="border border-slate-200 rounded-lg px-3 py-1.5 text-xs text-slate-600 bg-white focus:outline-none">
          <option value="">All Statuses</option>
          <option value="1">Active</option>
          <option value="2">Demo</option>
          <option value="3">Demo Expired</option>
        </select>
        <div id="region-chips" class="flex flex-wrap gap-1.5" data-active="">
          <button class="region-chip px-3 py-1.5 rounded-full text-xs font-semibold border bg-purple-600 text-white border-purple-600 transition-all" data-region="">All</button>
        </div>
        <input id="search-input" type="text" placeholder="Search company…" class="border border-slate-200 rounded-lg px-3 py-1.5 text-xs focus:outline-none min-w-36"/>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-100">
            <th class="text-left px-5 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Company ID</th>
            <th class="text-left px-5 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Company Name</th>
            <th class="text-left px-5 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Region</th>
            <th class="text-left px-5 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Status</th>
            <th class="text-left px-5 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Notes</th>
          </tr>
        </thead>
        <tbody id="companies-tbody">
          <tr><td colspan="5" class="text-center text-slate-300 py-10 text-sm">No data loaded</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</main>

<!-- NOTES MODAL -->
<div id="notes-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 hidden">
  <div class="bg-white rounded-2xl p-8 w-full max-w-md shadow-2xl mx-4">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:linear-gradient(135deg,#1a0533,#3b0764)">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      </div>
      <div>
        <h2 class="text-lg font-bold text-slate-800">Company Notes</h2>
        <p class="text-slate-400 text-xs font-mono" id="notes-company-id">—</p>
      </div>
    </div>
    <p class="text-sm font-semibold text-slate-700 mb-2" id="notes-company-name">—</p>
    <textarea id="notes-input" rows="4" placeholder="Add notes, action items, follow-up remarks…" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 focus:outline-none focus:ring-2 resize-none mb-4"></textarea>
    <div class="flex justify-end gap-3">
      <button id="notes-cancel-btn" class="px-4 py-2 text-sm text-slate-600 hover:bg-slate-100 rounded-lg">Cancel</button>
      <button id="notes-save-btn" class="px-6 py-2 text-white rounded-lg text-sm font-bold" style="background:linear-gradient(135deg,#1a0533,#3b0764)">Save Notes</button>
    </div>
  </div>
</div>

<!-- ERASE MODAL -->
<div id="erase-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 hidden">
  <div class="bg-white rounded-2xl p-8 w-full max-w-md shadow-2xl mx-4">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
      </div>
      <div>
        <h2 class="text-lg font-bold text-slate-800">Erase Month Data</h2>
        <p class="text-red-500 text-sm font-semibold" id="erase-month-label">—</p>
      </div>
    </div>
    <p class="text-slate-500 text-sm mb-4">This cannot be undone. Enter admin password to confirm.</p>
    <input type="password" id="erase-password-input" placeholder="Enter password" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-red-400 mb-2"/>
    <p id="erase-error" class="text-red-500 text-xs hidden mb-2">Incorrect password. Try again.</p>
    <div class="flex justify-end gap-3 mt-5">
      <button id="erase-cancel-btn" class="px-4 py-2 text-sm text-slate-600 hover:bg-slate-100 rounded-lg">Cancel</button>
      <button id="erase-confirm-btn" class="px-6 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg text-sm font-bold">Yes, Erase</button>
    </div>
  </div>
</div>

<!-- UPLOAD MODAL -->
<div id="upload-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 hidden">
  <div class="bg-white rounded-2xl p-8 w-full max-w-md shadow-2xl mx-4">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:linear-gradient(135deg,#f43f5e,#fb923c)">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
      </div>
      <div>
        <h2 class="text-lg font-bold text-slate-800">Upload Monthly Report</h2>
        <p class="text-slate-400 text-xs">Select the month this file belongs to</p>
      </div>
    </div>

    <!-- Month + Year selector -->
    <div class="grid grid-cols-2 gap-3 mb-5">
      <div>
        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1 block">Month</label>
        <select id="upload-month" class="w-full border border-slate-200 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 bg-white">
          {MONTHS.map(m => <option value={m} selected={m === currentMonth}>{m}</option>)}
        </select>
      </div>
      <div>
        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1 block">Year</label>
        <input type="number" id="upload-year" value={currentYear} min="2020" max="2099" class="w-full border border-slate-200 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 focus:outline-none focus:ring-2"/>
      </div>
    </div>

    <!-- Password -->
    <div class="mb-4">
      <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1 block">Admin Password</label>
      <input type="password" id="upload-password" placeholder="Enter password to upload" class="w-full border border-slate-200 rounded-lg px-3 py-2.5 text-sm text-slate-700 focus:outline-none focus:ring-2"/>
      <p id="upload-error" class="text-red-500 text-xs mt-1 hidden">Incorrect password. Try again.</p>
    </div>

    <!-- Drop zone -->
    <div id="drop-zone" class="border-2 border-dashed border-slate-200 rounded-xl p-6 text-center hover:border-vf-coral transition-colors cursor-pointer">
      <div class="text-3xl mb-2">📊</div>
      <p class="text-slate-600 font-semibold text-sm">Drop CSV or Excel file here</p>
      <p class="text-slate-400 text-xs mt-1">Supports .csv, .xlsx, .xls</p>
      <input type="file" id="file-input" accept=".csv,.xlsx,.xls" class="hidden"/>
      <p id="selected-file" class="text-vf-coral text-xs mt-3 font-semibold hidden"></p>
    </div>

    <div id="upload-progress" class="hidden mt-4">
      <div class="w-full bg-slate-100 rounded-full h-1.5">
        <div class="h-1.5 rounded-full animate-pulse w-full" style="background:linear-gradient(135deg,#f43f5e,#fb923c)"></div>
      </div>
      <p class="text-xs text-slate-400 mt-2 text-center">Importing, please wait…</p>
    </div>

    <div class="flex justify-end gap-3 mt-5">
      <button id="cancel-btn" class="px-4 py-2 text-sm text-slate-600 hover:bg-slate-100 rounded-lg">Cancel</button>
      <button id="confirm-upload-btn" class="px-6 py-2 text-white rounded-lg text-sm font-bold disabled:opacity-40 transition-all" style="background:linear-gradient(135deg,#f43f5e,#fb923c)" disabled>
        Upload & Import
      </button>
    </div>
  </div>
</div>

</Layout>

<script>
import Chart from 'chart.js/auto';
import jsPDF from 'jspdf';
import autoTable from 'jspdf-autotable';
import * as XLSX from 'xlsx';

// ── CONFIG — fill these in after deploying your Apps Script ──────
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbw3XxKt9bBULIPvyZvRFPwMQZi_WoJ-8XuBUNw1fPdh0lDCueelT27ptZnuxta1z8ulzg/exec';
const SECRET_KEY = 'Companies@1234';        // ← must match Code.gs SECRET_KEY
// ─────────────────────────────────────────────────────────────────

let allCompanies = [];
let statusChart   = null;
let trendChart    = null;
let regionChart   = null;
let fyMonths      = [];
let currentFY     = '';
let lastKPIs      = {};
let lastLifecycle = [];

// ── API helpers ───────────────────────────────────────────────────
async function apiGet(params) {
  const r = await fetch(SCRIPT_URL + '?' + new URLSearchParams(params).toString());
  return r.json();
}
async function apiPost(data) {
  const r = await fetch(SCRIPT_URL, {
    method:  'POST',
    headers: { 'Content-Type': 'text/plain;charset=utf-8' },
    body:    JSON.stringify(data)
  });
  return r.json();
}

// ── Client-side Excel parser (replaces server-side excelParser.js) ─
function parseExcelDate(val) {
  if (!val) return null;
  if (typeof val === 'number') {
    const d = new Date((val - 25569) * 86400 * 1000);
    return isNaN(d) ? null : d.toISOString().slice(0, 19).replace('T', ' ');
  }
  if (typeof val === 'string') {
    const d = new Date(val);
    return isNaN(d) ? null : d.toISOString().slice(0, 19).replace('T', ' ');
  }
  return null;
}
function parseExcelFile(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = e => {
      try {
        const wb      = XLSX.read(new Uint8Array(e.target.result), { type: 'array' });
        const ws      = wb.Sheets[wb.SheetNames[0]];
        const rows    = XLSX.utils.sheet_to_json(ws);
        const records = rows.map(row => ({
          company_id:     String(row['Company Id']     || row['company_id']     || '').trim(),
          company_name:   String(row['Company Name']   || row['company_name']   || '').trim(),
          instance:       String(row['Instance']       || row['instance']       || '').trim().toLowerCase(),
          company_status: parseInt(row['Company Status']|| row['company_status']|| 0),
          status_label:   String(row['status_label']   || '').trim(),
          created_at:     parseExcelDate(row['created_at'] || row['Created At'] || null)
        })).filter(r => r.company_id && r.company_name);
        resolve(records);
      } catch (err) { reject(err); }
    };
    reader.onerror = reject;
    reader.readAsArrayBuffer(file);
  });
}

// ── INIT ──────────────────────────────────────────────
async function init() {
  document.getElementById('last-updated').textContent = `Last updated: ${new Date().toLocaleString()}`;
  try {
    const data = await apiGet({ action: 'loadAll' });
    if (data.error) throw new Error(data.error);
    applyFullData(data);
  } catch(e) {
    showToast(`✗ Could not load dashboard: ${e.message}. Check Apps Script deployment.`, 'error');
  }
  setupUploadModal();
  setupEraseModal();
  setupNotesModal();
  setupFilters();
  setupPDF();
}

// ── APPLY FULL DATA (one-shot render after loadAll) ───
function applyFullData(data) {
  currentFY = data.activeFY;
  fyMonths  = data.months || [];

  const tabsEl = document.getElementById('fy-tabs');
  tabsEl.innerHTML = (data.fiscalYears || []).map(fy => `
    <button class="fy-tab px-6 py-3 text-sm font-bold border-b-2 transition-all whitespace-nowrap ${fy===data.activeFY?'border-vf-coral text-vf-coral':'border-transparent text-slate-400 hover:text-slate-600'}" data-fy="${fy}">
      FY ${fy}
    </button>`).join('');
  tabsEl.querySelectorAll('.fy-tab').forEach(btn => btn.addEventListener('click', () => switchFY(btn.dataset.fy)));

  const sel = document.getElementById('month-select');
  sel.innerHTML = fyMonths.length
    ? fyMonths.map(m => `<option value="${m.month}|${m.year}" ${m.month===data.activeMonth&&+m.year===+data.activeYear?'selected':''}>${m.month} ${m.year}</option>`).join('')
    : '<option value="">No data for this FY yet</option>';

  if (!fyMonths.length) { clearDashboard(); return; }

  if (data.kpis) {
    lastKPIs = data.kpis;
    document.getElementById('kpi-active').textContent  = data.kpis.active;
    document.getElementById('kpi-demo').textContent    = data.kpis.demo;
    document.getElementById('kpi-expired').textContent = data.kpis.demo_expired;
    document.getElementById('kpi-total').textContent   = data.kpis.total;
    renderChart(data.kpis);
  }

  lastLifecycle = data.lifecycle || [];
  const activeIdx = fyMonths.findIndex(m => m.month === data.activeMonth && m.year === +data.activeYear);
  renderLifecycle(lastLifecycle, activeIdx);

  allCompanies = data.companies || [];
  renderTable(allCompanies);
  renderRegionChart();
  renderRegionChips();
  renderAttention(data.attention || []);
  renderFYTrend(data.fyTrend || [], fyMonths);
}

// ── FY SWITCH (1 API call) ────────────────────────────
async function switchFY(fy) {
  document.querySelectorAll('.fy-tab').forEach(btn => {
    const a = btn.dataset.fy === fy;
    btn.className = `fy-tab px-6 py-3 text-sm font-bold border-b-2 transition-all whitespace-nowrap ${a?'border-vf-coral text-vf-coral':'border-transparent text-slate-400 hover:text-slate-600'}`;
  });
  const data = await apiGet({ action: 'loadAll', fy });
  applyFullData(data);
}

// ── MONTH SWITCH (1 API call) ─────────────────────────
async function loadDashboard() {
  const sel = document.getElementById('month-select');
  if (!sel.value || !sel.value.includes('|')) return;
  const [month, year] = sel.value.split('|');
  const idx  = fyMonths.findIndex(m => m.month === month && m.year === +year);
  const prev = idx > 0 ? fyMonths[idx - 1] : null;
  const data = await apiGet({ action: 'loadMonthData', month, year, prevMonth: prev?.month || '', prevYear: prev?.year || 0 });
  lastKPIs = data.kpis;
  document.getElementById('kpi-active').textContent  = data.kpis.active;
  document.getElementById('kpi-demo').textContent    = data.kpis.demo;
  document.getElementById('kpi-expired').textContent = data.kpis.demo_expired;
  document.getElementById('kpi-total').textContent   = data.kpis.total;
  renderChart(data.kpis);
  lastLifecycle = data.lifecycle;
  renderLifecycle(data.lifecycle, idx);
  allCompanies = data.companies;
  renderTable(allCompanies);
  renderRegionChart();
  renderRegionChips();
  renderAttention(data.attention);
}

// ── REFRESH (after import or erase) ──────────────────
async function refreshAll() {
  const sel = document.getElementById('month-select');
  const [month, year] = sel.value?.includes('|') ? sel.value.split('|') : ['', ''];
  const data = await apiGet({ action: 'loadAll', fy: currentFY, month, year });
  applyFullData(data);
}

function renderChart(kpis) {
  const ctx = document.getElementById('statusChart').getContext('2d');
  if (statusChart) statusChart.destroy();
  statusChart = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Active','Demo','Demo Expired'],
      datasets:[{ data:[kpis.active,kpis.demo,kpis.demo_expired], backgroundColor:['#10b981','#3b82f6','#f43f5e'], borderWidth:3, borderColor:'#fff' }]
    },
    options: { responsive:true, maintainAspectRatio:false, cutout:'72%',
      plugins:{ legend:{ position:'bottom', labels:{ padding:16, font:{size:11}, usePointStyle:true } } }
    }
  });
}

function renderLifecycle(changes, monthIdx) {
  const el  = document.getElementById('lifecycle-list');
  const sum = document.getElementById('lifecycle-summary');
  if (monthIdx <= 0) {
    sum.classList.add('hidden');
    el.innerHTML = '<p class="text-slate-300 text-sm text-center py-8">No previous month to compare</p>';
    return;
  }
  const converted = changes.filter(c=>c.from_status===2&&c.to_status===1).length;
  const expired   = changes.filter(c=>c.to_status===3).length;
  const reengaged = changes.filter(c=>c.from_status===3&&c.to_status===2).length;
  document.getElementById('lc-converted').textContent = converted;
  document.getElementById('lc-expired').textContent   = expired;
  document.getElementById('lc-reengaged').textContent = reengaged;
  sum.classList.toggle('hidden', changes.length===0);
  if (!changes.length) {
    el.innerHTML = '<p class="text-slate-300 text-sm text-center py-6">No status changes from previous month</p>';
    return;
  }
  el.innerHTML = changes.map(c=>`
    <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-slate-50 hover:bg-slate-100">
      <span class="text-sm font-semibold text-slate-700 truncate max-w-32">${c.company_id}</span>
      <div class="flex items-center gap-2">
        <span class="px-2 py-0.5 rounded-full text-xs font-bold ${badge(c.from_status)}">${c.from_label}</span>
        <svg class="w-3 h-3 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        <span class="px-2 py-0.5 rounded-full text-xs font-bold ${badge(c.to_status)}">${c.to_label}</span>
      </div>
    </div>`).join('');
}

function badge(s) {
  if (s===1) return 'bg-emerald-100 text-emerald-700';
  if (s===2) return 'bg-blue-100 text-blue-700';
  return 'bg-red-100 text-red-600';
}

