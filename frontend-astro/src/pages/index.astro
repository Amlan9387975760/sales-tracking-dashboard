// ── REGION CHIPS ──────────────────────────────────────
function renderRegionChips() {
  const LABEL = { us:'US', india:'India', europe:'Europe', uae:'UAE' };
  const container = document.getElementById('region-chips');
  const activeVal = container.dataset.active || '';
  const regions = [...new Set(allCompanies.map(c => (c.instance||'').toLowerCase()).filter(Boolean))].sort();
  const chips = [{ v:'', l:'All' }, ...regions.map(r => ({ v:r, l: LABEL[r] || r.toUpperCase() }))];
  container.innerHTML = chips.map(({v,l}) => {
    const on = v === activeVal;
    return `<button class="region-chip px-3 py-1.5 rounded-full text-xs font-semibold border transition-all ${on?'bg-purple-600 text-white border-purple-600':'bg-white text-slate-500 border-slate-200 hover:border-purple-500 hover:text-purple-600'}" data-region="${v}">${l}</button>`;
  }).join('');
}

function setupRegionChips() {
  document.getElementById('region-chips').addEventListener('click', e => {
    const chip = e.target.closest('.region-chip');
    if (!chip) return;
    document.getElementById('region-chips').dataset.active = chip.dataset.region;
    renderRegionChips();
    filterCompanies();
  });
}

function clearDashboard() {
  ['kpi-active','kpi-demo','kpi-expired','kpi-total'].forEach(id=>document.getElementById(id).textContent='—');
  document.getElementById('lifecycle-list').innerHTML='<p class="text-slate-300 text-sm text-center py-8">No data for this FY yet</p>';
  document.getElementById('attention-list').innerHTML='<p class="text-slate-300 text-sm col-span-full text-center py-4">No data</p>';
  document.getElementById('companies-tbody').innerHTML='<tr><td colspan="5" class="text-center text-slate-300 py-10 text-sm">No data for this FY yet</td></tr>';
