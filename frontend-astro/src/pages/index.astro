  if (regionChart) { regionChart.destroy(); regionChart=null; }
  document.getElementById('trend-fy-label').textContent = '';
  document.getElementById('region-chips').innerHTML = '<button class="region-chip px-3 py-1.5 rounded-full text-xs font-semibold border bg-purple-600 text-white border-purple-600" data-region="">All</button>';
  document.getElementById('region-chips').dataset.active = '';
}

// ── FILTERS ───────────────────────────────────────────
function setupFilters() {
  document.getElementById('month-select').addEventListener('change', loadDashboard);
  document.getElementById('filter-status').addEventListener('change', filterCompanies);
  document.getElementById('search-input').addEventListener('input', filterCompanies);
  setupRegionChips();
}
function filterCompanies() {
  const s = document.getElementById('filter-status').value;
  const i = document.getElementById('region-chips').dataset.active || '';
  const q = document.getElementById('search-input').value.toLowerCase();
  renderTable(allCompanies.filter(c=>
    (!s||String(c.company_status)===s)&&
    (!i||(c.instance||'').toLowerCase()===i)&&
    (!q||c.company_name.toLowerCase().includes(q)||String(c.company_id).toLowerCase().includes(q))
  ));
}

// ── NOTES MODAL ───────────────────────────────────────
function setupNotesModal() {
  document.getElementById('notes-cancel-btn').addEventListener('click', closeNotes);
  document.getElementById('notes-modal').addEventListener('click', e => { if(e.target===document.getElementById('notes-modal')) closeNotes(); });
  document.getElementById('notes-save-btn').addEventListener('click', saveNotes);

  // Event delegation — handles dynamically rendered rows
  document.getElementById('companies-tbody').addEventListener('click', e => {
    const btn = e.target.closest('.notes-btn');
    if (!btn) return;
    const id    = btn.dataset.id;
    const name  = btn.dataset.name;
    const notes = btn.dataset.notes;
    document.getElementById('notes-company-id').textContent  = id;
    document.getElementById('notes-company-name').textContent = name;
    document.getElementById('notes-input').value             = notes || '';
    document.getElementById('notes-modal')._companyId        = id;
    document.getElementById('notes-modal').classList.remove('hidden');
  });
}

async function saveNotes() {
  const modal = document.getElementById('notes-modal');
  const companyId = modal._companyId;
  const notes = document.getElementById('notes-input').value.trim();
  const btn = document.getElementById('notes-save-btn');
  btn.textContent = 'Saving…'; btn.disabled = true;
  try {
    const d = await apiPost({ action: 'updateNotes', key: SECRET_KEY, company_id: companyId, notes });
    if (!d.success) throw new Error(d.error || 'Failed to save notes');
    const co = allCompanies.find(c => String(c.company_id) === String(companyId));
    if (co) { co.notes = notes; renderTable(allCompanies); }
    closeNotes();
    showToast('✓ Notes saved', 'success');
  } catch(e) { showToast(`✗ Failed to save notes: ${e.message}`, 'error'); }
  finally { btn.textContent = 'Save Notes'; btn.disabled = false; }
}

function closeNotes() { document.getElementById('notes-modal').classList.add('hidden'); }

// ── UPLOAD MODAL ──────────────────────────────────────
function setupUploadModal() {
  const modal=document.getElementById('upload-modal');
  const fi=document.getElementById('file-input');
  const dz=document.getElementById('drop-zone');
  const cb=document.getElementById('confirm-upload-btn');
  const sel=document.getElementById('selected-file');

  document.getElementById('upload-btn').addEventListener('click',()=>modal.classList.remove('hidden'));
  document.getElementById('cancel-btn').addEventListener('click',closeUpload);
  modal.addEventListener('click',e=>{if(e.target===modal)closeUpload();});

  dz.addEventListener('click',()=>fi.click());
  dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('border-vf-coral');});
  dz.addEventListener('dragleave',()=>dz.classList.remove('border-vf-coral'));
  dz.addEventListener('drop',e=>{e.preventDefault();dz.classList.remove('border-vf-coral');if(e.dataTransfer.files[0])setFile(e.dataTransfer.files[0]);});
  fi.addEventListener('change',()=>{if(fi.files[0])setFile(fi.files[0]);});

  function setFile(f){ sel.textContent=`Selected: ${f.name}`; sel.classList.remove('hidden'); cb.disabled=false; cb._file=f; }

  function closeUpload(){ modal.classList.add('hidden'); fi.value=''; sel.classList.add('hidden'); cb.disabled=true; document.getElementById('upload-progress').classList.add('hidden'); document.getElementById('upload-password').value=''; document.getElementById('upload-error').classList.add('hidden'); }

  cb.addEventListener('click', async()=>{
    if(!cb._file) return;
    document.getElementById('upload-progress').classList.remove('hidden');
    cb.disabled=true;

    const pw    = document.getElementById('upload-password').value.trim();
    const month = document.getElementById('upload-month').value;
    const year  = +document.getElementById('upload-year').value;
    document.getElementById('upload-error').classList.add('hidden');

    try{
      const records = await parseExcelFile(cb._file);
      const d = await apiPost({ action: 'importData', password: pw, month, year, records });
      closeUpload();
      if(d.success){
        showToast(`✓ Imported ${d.total} companies — ${d.month} ${d.year} (FY ${d.fiscalYear})`,'success');
        await refreshAll();
        if(d.instanceErrors && d.instanceErrors.length > 0){
          const list = d.instanceErrors.map(e=>`${e.company_name} (file: ${e.file_instance}, stored: ${e.db_instance})`).join(' · ');
          setTimeout(()=>showToast(`⚠ ${d.instanceErrors.length} instance mismatch${d.instanceErrors.length>1?'es':''} — original kept. ${list}`,'warning'), 2000);
        }
      }
      else if(d.error==='Incorrect password'){ document.getElementById('upload-error').classList.remove('hidden'); document.getElementById('upload-progress').classList.add('hidden'); cb.disabled=false; return; }
      else showToast(`✗ ${d.error}`,'error');
    }catch(e){ showToast(`✗ ${e.message}`,'error'); }
    finally{ cb.disabled=false; }
  });
}

// ── ERASE MODAL ───────────────────────────────────────
function setupEraseModal() {
  const modal=document.getElementById('erase-modal');
  const pi=document.getElementById('erase-password-input');
  const err=document.getElementById('erase-error');
  const cb=document.getElementById('erase-confirm-btn');

  document.getElementById('erase-btn').addEventListener('click',()=>{
    const sel=document.getElementById('month-select');
    if(!sel.value||!sel.value.includes('|')) return;
    const [m,y]=sel.value.split('|');
    document.getElementById('erase-month-label').textContent=`${m} ${y}`;
    pi.value=''; err.classList.add('hidden');
    modal.classList.remove('hidden');
  });

  document.getElementById('erase-cancel-btn').addEventListener('click',closeErase);
  modal.addEventListener('click',e=>{if(e.target===modal)closeErase();});

  cb.addEventListener('click', async()=>{
    const pw=pi.value.trim(); if(!pw) return;
    const [m,y]=document.getElementById('month-select').value.split('|');
    cb.disabled=true; cb.textContent='Erasing…'; err.classList.add('hidden');
    try{
      const d = await apiPost({ action: 'eraseMonth', month: m, year: +y, password: pw });
      if(d.success){ closeErase(); showToast(`✓ Data for ${m} ${y} erased`,'success'); await refreshAll(); }
      else{ err.textContent=d.error||'Incorrect password'; err.classList.remove('hidden'); }
    }catch(e){ err.textContent='Error: '+e.message; err.classList.remove('hidden'); }
    finally{ cb.disabled=false; cb.textContent='Yes, Erase'; }
  });

  function closeErase(){ modal.classList.add('hidden'); pi.value=''; err.classList.add('hidden'); }
}

// ── PDF EXPORT ────────────────────────────────────────
function setupPDF() {
  document.getElementById('pdf-btn').addEventListener('click', () => generatePDF());
}

async function generatePDF() {
  const sel = document.getElementById('month-select');
  if (!sel.value || !sel.value.includes('|')) { showToast('Select a month first', 'error'); return; }
  const [month, year] = sel.value.split('|');

  const doc = new jsPDF({ unit: 'mm', format: 'a4' });
  const PW = 210, ML = 14, MR = 14, CW = PW - ML - MR;
  const NAVY  = [26, 5, 51];
  const CORAL = [244, 63, 94];
  const GREEN = [16, 185, 129];
  const BLUE  = [59, 130, 246];
  const PURPLE = [109, 40, 217];

  // Load logo as base64
  let logoDataUrl = null;
  try {
    const resp = await fetch('/logo.png');
    const blob = await resp.blob();
    logoDataUrl = await new Promise(res => { const r = new FileReader(); r.onloadend = () => res(r.result); r.readAsDataURL(blob); });
  } catch(_) {}

  // ── PAGE 1 HEADER ─────────────────────────────────────
  doc.setFillColor(...NAVY);
  doc.rect(0, 0, PW, 34, 'F');
  doc.setFillColor(...CORAL);
  doc.rect(0, 34, PW, 2.5, 'F');

  if (logoDataUrl) {
    try { doc.addImage(logoDataUrl, 'PNG', ML, 7, 22, 20); } catch(_) {}
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(15); doc.setFont('helvetica', 'bold');
    doc.text('Sales Intelligence Report', ML + 26, 17);
    doc.setFontSize(8.5); doc.setFont('helvetica', 'normal');
    doc.setTextColor(196, 181, 253);
    doc.text(`${month} ${year}  ·  FY ${currentFY}  ·  Exported ${new Date().toLocaleDateString('en-GB')}`, ML + 26, 26);
  } else {
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(15); doc.setFont('helvetica', 'bold');
    doc.text('Vantage Fit — Sales Intelligence Report', ML, 17);
    doc.setFontSize(8.5); doc.setFont('helvetica', 'normal');
    doc.setTextColor(196, 181, 253);
    doc.text(`${month} ${year}  ·  FY ${currentFY}  ·  Exported ${new Date().toLocaleDateString('en-GB')}`, ML, 27);
  }

  // ── KPI BOXES ─────────────────────────────────────────
  const kpiItems = [
    { label: 'ACTIVE',        value: lastKPIs.active       ?? '—', color: GREEN  },
    { label: 'DEMO',          value: lastKPIs.demo         ?? '—', color: BLUE   },
    { label: 'DEMO EXPIRED',  value: lastKPIs.demo_expired ?? '—', color: CORAL  },
    { label: 'TOTAL',         value: lastKPIs.total        ?? '—', color: PURPLE },
  ];
  const kBW = (CW - 9) / 4;
  kpiItems.forEach((k, i) => {
    const kx = ML + i * (kBW + 3), ky = 41;
    doc.setFillColor(...k.color);
    doc.roundedRect(kx, ky, kBW, 23, 2, 2, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(19); doc.setFont('helvetica', 'bold');
    doc.text(String(k.value), kx + kBW / 2, ky + 13, { align: 'center' });
    doc.setFontSize(6.5); doc.setFont('helvetica', 'normal');
    doc.text(k.label, kx + kBW / 2, ky + 20, { align: 'center' });
  });

  let curY = 70;

  const active  = allCompanies.filter(c => c.company_status === 1);
  const demo    = allCompanies.filter(c => c.company_status === 2);
  const expired = allCompanies.filter(c => c.company_status === 3);
  const compRow = c => [
    c.company_id, c.company_name, (c.instance || '').toUpperCase(),
    c.created_at ? new Date(c.created_at).toLocaleDateString('en-GB') : '—',
    c.notes || '—'
  ];
  const HEAD = [['ID', 'Company Name', 'Region', 'Created', 'Notes']];
  const COLS = { 0:{cellWidth:26}, 1:{cellWidth:52}, 2:{cellWidth:16}, 3:{cellWidth:22}, 4:{cellWidth:'auto'} };
  const MARG = { left: ML, right: MR, bottom: 15, top: 14 };

  function band(title, count, color, y) {
    doc.setFillColor(...color);
    doc.rect(ML, y, CW, 8, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(8.5); doc.setFont('helvetica', 'bold');
    doc.text(title, ML + 3, y + 5.5);
    doc.setFontSize(8); doc.setFont('helvetica', 'normal');
    doc.text(String(count), PW - MR - 3, y + 5.5, { align: 'right' });
    return y + 8;
  }

  function miniHdr(color) {
    return (data) => {
      if (data.pageNumber > 1) {
        doc.setFillColor(...NAVY);
        doc.rect(0, 0, PW, 11, 'F');
        doc.setFillColor(...color);
        doc.rect(0, 11, PW, 1.5, 'F');
        doc.setTextColor(196, 181, 253);
        doc.setFontSize(6.5); doc.setFont('helvetica', 'normal');
        doc.text(`Vantage Fit Sales Intelligence  ·  ${month} ${year}  ·  FY ${currentFY}`, ML, 7.5);
      }
    };
  }

  function tableOpts(color, altFill, cb) {
    return {
      head: HEAD, margin: MARG,
      headStyles: { fillColor: color, textColor: 255, fontSize: 7, fontStyle: 'bold', cellPadding: 2.5 },
      bodyStyles: { fontSize: 7, textColor: [40, 40, 40], cellPadding: 2.5 },
      alternateRowStyles: { fillColor: altFill },
      theme: 'grid', columnStyles: COLS,
      styles: { lineColor: [220, 220, 228], lineWidth: 0.2 },
      didDrawPage: cb
    };
  }

  // ── ACTIVE ────────────────────────────────────────────
  curY = band('Active Companies', active.length, GREEN, curY);
  autoTable(doc, { ...tableOpts(GREEN, [240, 253, 244], miniHdr(GREEN)), startY: curY,
    body: active.length ? active.map(compRow) : [['No active companies', '', '', '', '']] });
  curY = doc.lastAutoTable.finalY + 8;

  // ── DEMO ──────────────────────────────────────────────
  if (curY > 255) { doc.addPage(); curY = 14; }
  curY = band('Demo Companies', demo.length, BLUE, curY);
  autoTable(doc, { ...tableOpts(BLUE, [239, 246, 255], miniHdr(BLUE)), startY: curY,
    body: demo.length ? demo.map(compRow) : [['No demo companies', '', '', '', '']] });
  curY = doc.lastAutoTable.finalY + 8;

  // ── DEMO EXPIRED ──────────────────────────────────────
  if (curY > 255) { doc.addPage(); curY = 14; }
  curY = band('Demo Expired Companies', expired.length, CORAL, curY);
  autoTable(doc, { ...tableOpts(CORAL, [255, 241, 242], miniHdr(CORAL)), startY: curY,
    body: expired.length ? expired.map(compRow) : [['No expired companies', '', '', '', '']] });
  curY = doc.lastAutoTable.finalY + 8;

  // ── LIFECYCLE ─────────────────────────────────────────
  if (curY > 245) { doc.addPage(); curY = 14; }
  curY = band(`Lifecycle Movement — vs Previous Month`, lastLifecycle.length, NAVY, curY);
  autoTable(doc, {
    startY: curY,
    head: [['Company ID', 'Previous Status', '→', 'Current Status']],
    body: lastLifecycle.length
      ? lastLifecycle.map(c => [c.company_id, c.from_label, '→', c.to_label])
      : [['No lifecycle changes this month', '', '', '']],
    headStyles: { fillColor: NAVY, textColor: 255, fontSize: 7, fontStyle: 'bold', cellPadding: 2.5 },
    bodyStyles: { fontSize: 7, textColor: [40, 40, 40], cellPadding: 2.5 },
    alternateRowStyles: { fillColor: [248, 246, 254] },
    margin: MARG, theme: 'grid',
    columnStyles: { 2: { halign: 'center', cellWidth: 12 } },
    styles: { lineColor: [220, 220, 228], lineWidth: 0.2 },
    didDrawPage: miniHdr(NAVY)
  });

  // ── FOOTER ALL PAGES ──────────────────────────────────
  const totalPages = doc.getNumberOfPages();
  for (let p = 1; p <= totalPages; p++) {
    doc.setPage(p);
    doc.setFillColor(...NAVY);
    doc.rect(0, 287, PW, 10, 'F');
    doc.setTextColor(196, 181, 253);
    doc.setFontSize(6.5); doc.setFont('helvetica', 'normal');
    doc.text('Vantage Fit Sales Intelligence  ·  Confidential — Internal Use Only', ML, 293);
    doc.text(`Page ${p} of ${totalPages}`, PW - MR, 293, { align: 'right' });
  }

  doc.save(`VantageFit_Sales_${month}_${year}.pdf`);
  showToast('✓ PDF downloaded successfully', 'success');
}

// ── TOAST ─────────────────────────────────────────────
function showToast(msg, type) {
  const t = document.getElementById('toast');
  const styles = {
    success: 'bg-emerald-500 text-white',
    error:   'bg-red-500 text-white',
    warning: 'bg-amber-500 text-white'
  };
  t.className = `fixed top-20 right-6 z-50 px-5 py-3 rounded-xl text-sm font-semibold shadow-xl max-w-md leading-relaxed ${styles[type]||styles.error}`;
  t.textContent = msg;
  t.classList.remove('hidden');
  setTimeout(()=>t.classList.add('hidden'), type==='warning' ? 8000 : 4000);
}

init();
</script>
</Layout>
